<Application x:Class="Net10.Wpf.MinimalAPI.IssueBoard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Net10.Wpf.MinimalAPI.IssueBoard"
             xmlns:vm="clr-namespace:Net10.Wpf.MinimalAPI.IssueBoard.ViewModels"
             xmlns:views="clr-namespace:Net10.Wpf.MinimalAPI.IssueBoard.Views"
             xmlns:converters="clr-namespace:Net10.Wpf.MinimalAPI.IssueBoard.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- コンバーター -->
        <converters:IssueStatusConverter        x:Key="IssueStatusConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <!-- フォームラベルスタイル -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin"              Value="0,8,8,0"/>
            <Setter Property="VerticalAlignment"   Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="FontWeight"          Value="SemiBold"/>
        </Style>

        <!-- フォーム値表示スタイル -->
        <Style x:Key="FormValueStyle" TargetType="TextBlock">
            <Setter Property="Margin"            Value="0,8,0,0"/>
            <Setter Property="TextWrapping"      Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- フォームテキストボックススタイル -->
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin"  Value="0,5,0,0"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- ViewModel → View マッピング -->
        <DataTemplate DataType="{x:Type vm:IssueListViewModel}">
            <views:IssueListView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IssueDetailViewModel}">
            <views:IssueDetailView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IssueEditViewModel}">
            <views:IssueEditView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IssueDeleteViewModel}">
            <views:IssueDeleteView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:IssueCreateViewModel}">
            <views:IssueCreateView/>
        </DataTemplate>

    </Application.Resources>
</Application>
