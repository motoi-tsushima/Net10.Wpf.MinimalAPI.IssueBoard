<UserControl x:Class="Net10.Wpf.MinimalAPI.IssueBoard.Views.IssueEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <DockPanel Margin="15">

        <!-- タイトル -->
        <TextBlock DockPanel.Dock="Top"
                   Text="課題内容編集"
                   FontSize="18" FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- エラー表示 + ボタン (常に画面下部) -->
        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red" FontWeight="Bold"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                       Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="更新"
                        Command="{Binding UpdateCommand}"
                        Width="110" Height="32" Margin="6,0"/>
                <Button Content="戻る"
                        Command="{Binding BackCommand}"
                        Width="110" Height="32" Margin="6,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 編集フォーム (スクロール可) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 記入者氏名 (読取専用) -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="記入者氏名:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AuthorName}"
                           Style="{StaticResource FormValueStyle}"/>

                <!-- 登録日時 (読取専用) -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="登録日時:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CreatedAtDisplay}"
                           Style="{StaticResource FormValueStyle}"/>

                <!-- カテゴリ名 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="カテゴリ名:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Category}"
                         Style="{StaticResource FormTextBoxStyle}"/>

                <!-- 課題タイトル -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="課題タイトル *:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Title}"
                         Style="{StaticResource FormTextBoxStyle}"/>

                <!-- 課題の文面 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="課題の文面 *:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Description}"
                         TextWrapping="Wrap" Height="120" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource FormTextBoxStyle}"/>

                <!-- 現在の状況 -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="現在の状況:"
                           Style="{StaticResource FormLabelStyle}"/>
                <ComboBox Grid.Row="5" Grid.Column="1"
                          ItemsSource="{Binding StatusItems}"
                          SelectedValue="{Binding SelectedStatus}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="DisplayName"
                          Width="200" HorizontalAlignment="Left"
                          Margin="0,5,0,0"/>

                <!-- 解決の文面 -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="解決の文面:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Resolution}"
                         TextWrapping="Wrap" Height="120" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Style="{StaticResource FormTextBoxStyle}"/>

                <!-- 解決担当者名 -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="解決担当者名:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ResolverName}"
                         Style="{StaticResource FormTextBoxStyle}"/>

                <!-- 最終結果日時 (自動設定) -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="最終結果日時:"
                           Style="{StaticResource FormLabelStyle}"/>
                <TextBlock Grid.Row="8" Grid.Column="1" Text="更新時に自動設定"
                           Style="{StaticResource FormValueStyle}" Foreground="Gray"/>
            </Grid>
        </ScrollViewer>

    </DockPanel>
</UserControl>
